set $rosewater #f5e0dc
set $flamingo  #f2cdcd
set $pink      #f5c2e7
set $mauve     #cba6f7
set $red       #f38ba8
set $maroon    #eba0ac
set $peach     #fab387
set $yellow    #f9e2af
set $green     #a6e3a1
set $teal      #94e2d5
set $sky       #89dceb
set $sapphire  #74c7ec
set $blue      #89b4fa
set $lavender  #b4befe
set $text      #cdd6f4
set $subtext1  #bac2de
set $subtext0  #a6adc8
set $overlay2  #9399b2
set $overlay1  #7f849c
set $overlay0  #6c7086
set $surface2  #585b70
set $surface1  #45475a
set $surface0  #313244
set $base      #1e1e2e
set $mantle    #181825
set $crust     #11111b

set $ws1 "1: 1"
set $ws2 "2: 2"
set $ws3 "3: 3"
set $ws4 "4: 4"
set $ws5 "5: 5"

set $mod Mod4

font pango:JetBrainsMono Nerd Font 10

floating_modifier $mod

tiling_drag modifier titlebar

focus_follows_mouse no

default_border          none
default_floating_border none

smart_borders on
smart_borders no_gaps

smart_gaps off

gaps inner 20
gaps outer 10

popup_during_fullscreen smart

# Use `assign`?
for_window [class="Alacritty"]       move container to workspace $ws1
for_window [class="firefox_firefox"] move container to workspace $ws2
for_window [class="Slack"]           move container to workspace $ws3
for_window [class="discord"]         move container to workspace $ws4

for_window [class="copyq"] floating enable, move position center, resize set 1000 800

for_window [window_role="GtkFileChooserDialog"] move position center, resize set 100 80

bindsym $mod+Tab workspace back_and_forth

bindsym $mod+slash exec --no-startup-id rofi -show window

bindsym $mod+c exec --no-startup-id rofi-copyq
bindsym $mod+d exec --no-startup-id rofi -show drun
bindsym $mod+f fullscreen toggle
bindsym $mod+g mode ""
bindsym $mod+h split h
bindsym $mod+l exec --no-startup-id i3lock-fancy -f JetBrainsMono Nerd Font
bindsym $mod+p layout toggle split
bindsym $mod+r mode "󰩨"
bindsym $mod+s layout stacking
bindsym $mod+t layout tabbed
bindsym $mod+q exec --no-startup-id i3-nagbar -t warning -f "pango:JetBrainsMono Nerd Font 10" -m "Exit?" -B "    " "i3-msg exit" -B "    " "pkill i3-nagbar && i3lock-fancy -f JetBrainsMono Nerd Font" -B "    " "pkill i3-nagbar && reboot" -B "    " "pkill i3-nagbar && shutdown -h now"
bindsym $mod+v exec --no-startup-id dunstctl history-pop
bindsym $mod+w kill
bindsym $mod+x i3lock-fancy -f JetBrainsMono Nerd Font
bindsym $mod+z reload

bindsym $mod+Shift+q exec i3-msg exit
bindsym $mod+Shift+v exec --no-startup-id dunstctl close
bindsym $mod+Shift+z restart

bindsym $mod+n focus left
bindsym $mod+e focus down
bindsym $mod+i focus up
bindsym $mod+o focus right

bindsym $mod+Left  focus left
bindsym $mod+Down  focus down
bindsym $mod+Up    focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+n move left
bindsym $mod+Shift+e move down
bindsym $mod+Shift+i move up
bindsym $mod+Shift+o move right

bindsym $mod+Control+Left  move left
bindsym $mod+Control+Down  move down
bindsym $mod+Control+Up    move up
bindsym $mod+Control+Right move right

bindsym $mod+1 workspace number $ws1
bindsym $mod+3 workspace number $ws2
bindsym $mod+5 workspace number $ws3
bindsym $mod+7 workspace number $ws4
bindsym $mod+9 workspace number $ws5

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+3 move container to workspace number $ws2
bindsym $mod+Shift+5 move container to workspace number $ws3
bindsym $mod+Shift+7 move container to workspace number $ws4
bindsym $mod+Shift+9 move container to workspace number $ws5

bindsym Print exec --no-startup-id scrot -e 'xclip -selection clipboard -t image/png -i $f'

bindsym XF86AudioRaiseVolume exec amixer -q -D pulse sset Master 5%+
bindsym XF86AudioLowerVolume exec amixer -q -D pulse sset Master 5%-
bindsym XF86AudioMute        exec amixer -q -D pulse sset Master toggle

mode "󰩨" {
  bindsym n resize shrink width 10 px or 10 ppt
  bindsym e resize grow   height 10 px or 10 ppt
  bindsym i resize shrink height 10 px or 10 ppt
  bindsym o resize grow   width 10 px or 10 ppt

  bindsym Left  resize shrink width 10 px or 10 ppt
  bindsym Down  resize grow   height 10 px or 10 ppt
  bindsym Up    resize shrink height 10 px or 10 ppt
  bindsym Right resize grow   width 10 px or 10 ppt

  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym $mod+g mode ""
  bindsym $mod+r mode "default"
}

mode "" {
  bindsym n focus left
  bindsym e focus down
  bindsym i focus up
  bindsym o focus right

  bindsym Left  focus left
  bindsym Down  focus down
  bindsym Up    focus up
  bindsym Right focus right

  bindsym Shift+n move left
  bindsym Shift+e move down
  bindsym Shift+i move up
  bindsym Shift+o move right

  bindsym Control+Left  move left
  bindsym Control+Down  move down
  bindsym Control+Up    move up
  bindsym Control+Right move right

  bindsym 1 workspace number $ws1
  bindsym 3 workspace number $ws2
  bindsym 5 workspace number $ws3
  bindsym 7 workspace number $ws4
  bindsym 9 workspace number $ws5

  bindsym 2 workspace number $ws1
  bindsym 4 workspace number $ws2
  bindsym 6 workspace number $ws3
  bindsym 8 workspace number $ws4
  bindsym 0 workspace number $ws5

  bindsym Shift+1 move container to workspace number $ws1
  bindsym Shift+3 move container to workspace number $ws2
  bindsym Shift+5 move container to workspace number $ws3
  bindsym Shift+7 move container to workspace number $ws4
  bindsym Shift+9 move container to workspace number $ws5

  bindsym Shift+2 move container to workspace number $ws1
  bindsym Shift+4 move container to workspace number $ws2
  bindsym Shift+6 move container to workspace number $ws3
  bindsym Shift+8 move container to workspace number $ws4
  bindsym Shift+0 move container to workspace number $ws5

  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym $mod+g mode "default"
  bindsym $mod+r mode "󰩨"
}
                      # Border     Background  Text       Indicator   Child Border
client.focused          $blue      $mantle     $text      $teal       $blue
client.focused_inactive $blue      $mantle     $subtext0  $teal       $blue
client.unfocused        $base      $mantle     $subtext0  $teal       $base
client.urgent           $teal      $mantle     $teal      $teal       $teal
client.placeholder      $overlay0  $mantle     $text      $overlay0   $overlay0   

client.background $base

exec_always --no-startup-id dex --autostart --environment i3
exec_always --no-startup-id xautolock -time 5 -locker "i3lock-fancy -f JetBrainsMono Nerd Font"
exec_always --no-startup-id nm-applet
exec_always --no-startup-id feh --bg-fill ~/Pictures/shaded_landscape.png
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec_always --no-startup-id picom

exec --no-startup-id alacritty
exec --no-startup-id firefox
exec --no-startup-id slack
exec --no-startup-id discord
