[global]
monitor = 0
origin = top-right
font = JetBrains Mono Nerd Font 20
width = 320
height = (0, 320)
scale = 0
line_height = 0
padding = 10
horizontal_padding = 10
text_icon_padding = 0
gap_size = 0
separator_height = 2
separator_color = frame
frame_width = 1
frame_color = "#89b4fa"
highlight = "#89b4fa"
offset = (15, 15)
corner_radius = 0
alignment = left
vertical_alignment = center
icon_position = off
min_icon_size = 0
max_icon_size = 32
transparency = 0
follow = mouse
notification_limit = 0
progress_bar = false
indicate_hidden = yes
sort = yes
markup = full
idle_threshold = 120
show_age_threshold = 60
ellipsize = middle
ignore_newline = no
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
sticky_history = yes
history_length = 20
always_run_script = true
mouse_left_click = close_current
mouse_middle_click = do_action, close_current
mouse_right_click = close_all
ignore_dbusclose = false
force_xinerama = false

[urgency_low]
background = "#1e1e2e"
foreground = "#cdd6f4"
timeout = 10

[urgency_normal]
background = "#1e1e2e"
foreground = "#cdd6f4"
timeout = 10
override_pause_level = 30

[urgency_critical]
background = "#1e1e2e"
foreground = "#cdd6f4"
frame_color = "#fab387"
timeout = 10
override_pause_level = 60
